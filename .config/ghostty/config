# Theme
theme = Catppuccin Mocha

# Background
background-opacity = 0.90
background-blur = true

# Titlebar
macos-titlebar-style = hidden

# Fonts
font-size = 16

# Key Bindings
keybind = cmd+i=inspector:toggle

# Option key as a Meta key
macos-option-as-alt = true

# Save with Cmd+S in Vim
keybind = cmd+s=text:\x1b:w\r

# Other
mouse-hide-while-typing = true

# SSH
# Configure SSH to fall back to xterm-256color (same as tmux)
shell-integration-features = ssh-env

# Add `ghostty` to $PATH
shell-integration-features = path
